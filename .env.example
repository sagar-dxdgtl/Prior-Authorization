APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/preauth
APP_DB_URL=postgresql+psycopg://preauth_app:CHANGE_ME@localhost:5432/preauth
JWT_SECRET=dev-only-change-me-this-is-32-bytes-minimum
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=1209600
# example only — regenerate with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEYS=QeI9zVlX7a4XRe5A7JYoH72AaYhs-sJ2XRr_NscEc2c=
# Set to true in prod when FERNET_KEYS holds base64-encoded KMS ciphertext blobs instead of raw Fernet keys.
FERNET_KEYS_KMS=false
MEMBER_ID_PEPPER=dev-only-pepper-change-me-to-32plus-bytes
STEDI_API_KEY=
STEDI_ELIGIBILITY_URL=https://healthcare.us.stedi.com/2024-04-01/change/medicalnetwork/eligibility/v3
CORS_ORIGINS=http://localhost:5173
AWS_DEFAULT_REGION=us-east-1

# Per-payer Provider Directory FHIR creds (see docs/payer-sources/SIGNUP-CHECKLIST.md).
# OAuth2 client-credentials payers use <P>_FHIR_{BASE_URL,TOKEN_URL,CLIENT_ID,CLIENT_SECRET[,SCOPE]}.
# Anthem / Elevance BCBS (URLs are public; client_id/secret come from the developer portal):
ANTHEM_FHIR_BASE_URL=https://totalview.healthos.elevancehealth.com/resources/unregistered/api/v1/fhir/cms_mandate/mcd
ANTHEM_FHIR_TOKEN_URL=https://totalview.healthos.elevancehealth.com/client.oauth2/unregistered/api/v1/token
ANTHEM_FHIR_CLIENT_ID=
ANTHEM_FHIR_CLIENT_SECRET=
#ANTHEM_FHIR_SCOPE=
